<Window x:Class="NetOptimizer.Views.MainWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:conv="clr-namespace:NetOptimizer.Convertors"
        xmlns:local="clr-namespace:NetOptimizer"
        xmlns:helpers="clr-namespace:NetOptimizer.Helpers"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:NetOptimizer.Behaviors"
        mc:Ignorable="d"
        Icon="/Assets/Icons/gnologo.ico"
        Title="{Binding ProjectName}" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <conv:DeviceTypeToIconConverter x:Key="DeviceTypeToIconConverter"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:ToolTypeToShapeConverter x:Key="ToolTypeToShapeConverter"/>
            <conv:CanvasCursorModeToCursorConverter x:Key="CanvasCursorModeToCursorConverter"/>
            <conv:SelectionToEffectConverter x:Key="SelectionToEffectConverter"/>
            <conv:PortHeaderConverter x:Key="PortHeaderConverter"/>
            <conv:PortColorConverter x:Key="PortColorConverter"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <conv:ConnectionStateToBrushConverter x:Key="ConnectionStateToBrushConverter"/>
            <conv:PacketTypeToBrushConverter x:Key="PacketTypeToBrushConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/ResourcesDictionary/MainWindowResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>

    </Window.Resources>

    <DockPanel Background="#F8F8F8">
        <Menu DockPanel.Dock="Top" Background="White" BorderThickness="0,0,0,1" BorderBrush="#F0F0F0" Foreground="Black" Padding="5" Cursor="Hand">
            <MenuItem  Header="File">
                <MenuItem.Icon>
                    <Image Source="/Assets/Images/file.png" />
                </MenuItem.Icon>
                <MenuItem Header="Новый проект" />
                <MenuItem Header="Открыть проект" />
                <Separator />
                <MenuItem Header="Сохранить и выйти" />
            </MenuItem>
            <MenuItem Header="Edit" >
                <MenuItem.Icon>
                    <Image Source="/Assets/Images/edit.png" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem.Icon>
                    <Image Source="/Assets/Images/help.png" />
                </MenuItem.Icon>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" MinWidth="350" MaxWidth="450"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="500"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TabControl Grid.Row="3"
                            Background="Transparent"
                            BorderThickness="0"
                            TabStripPlacement="Bottom"
                            HorizontalAlignment="Stretch">
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                  Margin="0"
                                  ContentSource="SelectedContent"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                                <UniformGrid Rows="1" Columns="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Items.Count}" IsItemsHost="True" VerticalAlignment="Bottom"/>
                            </Grid>
                        </ControlTemplate>
                    </TabControl.Template>

                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,8"/>
                        </Style>
                    </TabControl.Resources>
                    <!--РЕЖИМ РЕДАКТОРА-->
                    <TabItem Style="{StaticResource ModernTabItemStyle}">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Source="/Assets/Images/redact.png" Width="18" Height="18" Margin="0,0,8,0"/>
                                <TextBlock Text="Редактор" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>

                        <ScrollViewer behaviors:ScrollBarWheelDirectionBehavior.OrientationScroll="Vertical"  Margin="0,0,0,40">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="КОНФИГУРАЦИЯ СЕТИ" Grid.Row="0" 
                                           HorizontalAlignment="Center" FontWeight="Bold" 
                                           Foreground="#555" Margin="0,10,0,20"/>

                                <StackPanel Grid.Row="2" Margin="0,0,0,15">
                                    <TextBlock Text="Группы:" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#333"/>

                                    <Border BorderBrush="#CECECE" BorderThickness="1" CornerRadius="8" Padding="10" Background="White">
                                        <Grid MaxHeight="120">
                                            <ScrollViewer behaviors:ScrollBarWheelDirectionBehavior.OrientationScroll="Vertical" Margin="0,0,0,5">
                                                <ItemsControl ItemsSource="{Binding editorViewModel.DeviceGroups}"
                                                              ItemTemplate="{StaticResource DeviceGroupItemTemplate}"/>
                                            </ScrollViewer>
                                            <Button Command="{Binding editorViewModel.OpenAddGroupWindowCommand}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Width="24" Height="24" Cursor="Hand" Margin="0,0,0,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid>
                                                            <Ellipse Fill="#2D6EE7"/>
                                                            <TextBlock Text="+" Foreground="White" FontWeight="Bold" 
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Row="3" Margin="0,0,0,15">
                                    <TextBlock Text="Устройства:" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#333"/>
                                    <ItemsControl ItemsSource="{Binding editorViewModel.AvailableDevices}"
                                                  ItemTemplateSelector="{StaticResource DeviceTemplateSelector}"/>
                                    
                                    <Separator Margin="10,15,10,0" Background="#EEE"/>
                                </StackPanel>


                                <StackPanel Grid.Row="5" VerticalAlignment="Bottom" >
                                    <Button Content="Создать" Command="{Binding editorViewModel.CreateNetworkByUserPropertiesCommand}"
                                            Height="30" Width="150" Foreground="White" FontWeight="SemiBold" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border x:Name="border" Background="#4A89F3" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#5B9AFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#3A79E3"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                </StackPanel>

                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                    <!--РЕЖИМ ПЕСОЧНИЦЫ-->
                    <TabItem Style="{StaticResource ModernTabItemStyle}">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Source="/Assets/Images/topology.png" Width="20" Height="20" Margin="0,0,5,0"/>
                                <TextBlock Text="Песочница" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Доступные устройства"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"
                                       FontWeight="Bold"
                                       Foreground="#888"
                                       FontSize="10"/>
                            <ScrollViewer  behaviors:ScrollBarWheelDirectionBehavior.OrientationScroll="Horizontal" Grid.Row="1"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Margin="10,5">
                                <ItemsControl ItemsSource="{Binding sandboxViewModel.AvailableDevices}" >
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="5"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Vertical" Margin="0,0,12,0" Cursor="Hand">
                                                <Border Padding="5"  x:Name="iconBorder" Background="White" BorderThickness="1"
                                                        BorderBrush="#EDEDED" Width="45" Height="45" CornerRadius="10"  >
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                       Command="{Binding DataContext.sandboxViewModel.OpenCreateDeviceWindowCommand, 
                                                                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                       CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10" Opacity="0.1" Direction="275" Color="LightGray"/>
                                                    </Border.Effect>
                                                    <Image UseLayoutRounding="True" Source="{Binding Type, Converter={StaticResource DeviceTypeToIconConverter}}" />
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#DEDEDE"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                                <TextBlock Text="{Binding DeviceName}"
                                                           HorizontalAlignment="Center"
                                                           FontSize="10"
                                                           Foreground="#555"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Grid.Row="2"
                                       Text="Библиотека элементов"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"
                                       FontWeight="Bold"
                                       Foreground="#888"
                                       FontSize="10"/>
                            <ScrollViewer behaviors:ScrollBarWheelDirectionBehavior.OrientationScroll="Horizontal" Grid.Row="3"
                                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"  Margin="10,5">
                                <ItemsControl ItemsSource="{Binding sandboxViewModel.AvailableTools}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="5"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Vertical" Margin="0,0,12,0" Cursor="Hand">
                                                <Border x:Name="iconBorder" Background="White" BorderThickness="1" 
                                                        BorderBrush="#EDEDED" Width="45" Height="45" CornerRadius="10" Effect="{Binding IsSelected, Converter={StaticResource SelectionToEffectConverter}}">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.sandboxViewModel.PrepareForDrawSelectedUIElementCommand, 
                                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                       CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>

                                                    <ContentControl Content="{Binding Type, Converter={StaticResource ToolTypeToShapeConverter}}"/>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#DEDEDE"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                                <TextBlock Text="{Binding ToolName}"
                                                           HorizontalAlignment="Center"
                                                           FontSize="10"
                                                           Foreground="#555"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>


                            <ScrollViewer behaviors:ScrollBarWheelDirectionBehavior.OrientationScroll="Vertical"
                                          Grid.Row="4" Margin="0,0,0,35"
                                          HorizontalScrollBarVisibility="Disabled"  
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Добавленные устройства"
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0"
                                               FontWeight="Bold"
                                               Foreground="#888"
                                               FontSize="10"/>

                                    <ListBox ItemsSource="{Binding CanvasVM.Devices}"
                                             SelectedItem="{Binding SelectedDevice}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             HorizontalContentAlignment="Stretch" Margin="0,5,0,0">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemBorder" Background="Transparent" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#F5F5F5"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#E3F2FD"/>
                                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2196F3"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Height="50" Background="Transparent" Padding="5,0">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Подключиться"
                                                                      Command="{Binding PlacementTarget.Tag.ConnectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <Image Source="/Assets/Images/connect.png"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>

                                                            <MenuItem Header="Изменить"
                                                                      Command="{Binding PlacementTarget.Tag.OpenUpdateDeviceWindowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <Image Source="/Assets/Images/reconnect.png"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator />

                                                            <MenuItem Header="Удалить" Foreground="Red"
                                                                      Command="{Binding PlacementTarget.Tag.RemoveDeviceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <Image Source="/Assets/Images/delete.png"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>

                                                    <Border.Tag>
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ListBox}" />
                                                    </Border.Tag>

                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Width="30" Height="30" Margin="10"
                                                               Source="{Binding LogicDevice.Type, Converter={StaticResource DeviceTypeToIconConverter}}" />
                                                        <StackPanel VerticalAlignment="Center">
                                                            <Label Content="{Binding DeviceName}" Foreground="Black" FontSize="14" Padding="0"/>
                                                            <TextBlock  Text="{Binding DeviceModel}" Foreground="Gray" FontSize="10" Margin="5,0,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>

                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                    <TabItem Style="{StaticResource ModernTabItemStyle}">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Source="/Assets/Images/labcolba.png" Width="20" Height="20" Margin="0,0,5,0"/>
                                <TextBlock Text="Симмуляция" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>

                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="90"/>
                            </Grid.RowDefinitions>

                            <!-- Заголовок -->
                            <TextBlock Text="Сценарий" Grid.Row="0"
                                       FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"  Foreground="#444"
                                       Margin="0,0,0,10"/>

                            <ComboBox Style="{StaticResource ScenarioComboBox}" Grid.Row="1"
                                      Width="250" Height="35"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,15"
                                      ItemsSource="{Binding simmulationViewModel.ScenarioList}"
                                      SelectedItem="{Binding simmulationViewModel.SelectedScenario}"
                                      DisplayMemberPath="Name"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      ItemContainerStyle="{StaticResource ScenarioComboBoxItem}">
                            </ComboBox>

                            <Grid Grid.Row="2" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Height="35" Grid.Column="1" Style="{StaticResource SimpleButtonStyle}" Command="{Binding simmulationViewModel.AddNewScenarioCommand}" Width="100">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="+" FontSize="18" Margin="0,-3,8,0"/>
                                        <TextBlock Text="Создать" FontSize="14" />
                                    </StackPanel>
                                </Button>
                                <Button Height="35" Grid.Column="3" Style="{StaticResource SimpleButtonStyle}" Command="{Binding simmulationViewModel.RemoveScenarioCommand}" Width="100">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Image Source="/Assets/Images/trashbucket.png" Width="20" Height="20" Margin="0,0,5,0"></Image>
                                        <TextBlock Text="Удалить"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <!-- Таблица сценариев -->
                            <Border Grid.Row="3"
                                    Background="White"
                                    CornerRadius="8"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    Margin="0,0,0,10">

                                <DataGrid Style="{StaticResource ScenarioDataGrid}" ItemsSource="{Binding simmulationViewModel.ActionsView}"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          RowBackground="White"
                                          AlternatingRowBackground="#F7F9FC"
                                          BorderThickness="0"
                                          IsReadOnly="True">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Источник"  Binding="{Binding SourceDevice.LogicDevice.Name}" Width="*" />
                                        <DataGridTextColumn Header="Цель" Binding="{Binding TargetDevice.LogicDevice.Name}" Width="*"/>
                                        <DataGridTextColumn Header="Тип" Binding="{Binding PacketType}" Width="*"/>
                                        <DataGridTemplateColumn Header="Цвет">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Width="16" Height="16"
                                                             CornerRadius="3" Background="{Binding PacketType, Converter={StaticResource PacketTypeToBrushConverter}}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Действие" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Редактировать"
                                                            Command="{Binding DataContext.RedactCommand,
                                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                           CommandParameter="{Binding}"
                                                           Visibility="{Binding IsValid, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                            <TextBlock Grid.Row="4" Text="Цепочка событий"
                                       FontSize="16"  HorizontalAlignment="Center"
                                       FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#444"/>
                            <!-- Цепочка событий -->
                            <Border Grid.Row="5"
                                    Background="White"
                                    CornerRadius="8"
                                    BorderBrush="#DDD"
                                    BorderThickness="1">

                      
                                    <ScrollViewer behaviors:ScrollBarWheelDirectionBehavior.OrientationScroll="Vertical">
                                        <DataGrid ItemsSource="{Binding simmulationViewModel.Events}"
            AutoGenerateColumns="False"
            HeadersVisibility="Column"
            GridLinesVisibility="None"
            RowBackground="White"
            AlternatingRowBackground="#F7F9FC"
            BorderThickness="0">

                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="От устройства" Binding="{Binding From}" Width="*"/>
                                                <DataGridTextColumn Header="К устройству" Binding="{Binding To}" Width="*"/>
                                                <DataGridTextColumn Header="Тип пакета" Binding="{Binding Type}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </ScrollViewer>

                                  
                            </Border>

                            <!-- Кнопка -->
                            <Button Grid.Row="6"
                                    Content="Начать симуляцию"
                                    Height="35" Width="150"
                                    HorizontalAlignment="Center"
                                    Foreground="White" FontWeight="SemiBold"
                                    Cursor="Hand" Background="#4A89F3"
                                    BorderThickness="0"
                                    Command="{Binding simmulationViewModel.StartSimmulationCommand}">

                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border"
                                                         Property="Background"
                                                         Value="#5B9AFF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#3A79E3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" 
                          Background="#F0F0F0" ShowsPreview="True" Cursor="SizeWE"/>

            <Grid Grid.Column="2" Background="#DFE3E6" ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="39*"/>
                    <RowDefinition Height="554*"/>
                </Grid.RowDefinitions>
                <Canvas x:Name="MainCanvas" Cursor="{Binding CanvasCursor, Converter={StaticResource CanvasCursorModeToCursorConverter}}"
                        DataContext="{Binding CanvasVM}" Width="{Binding CanvasWidth}"
                        Height="{Binding CanvasHeight}" Grid.RowSpan="2" Focusable="True" >

                    <Canvas.Background>
                        <VisualBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                            <VisualBrush.Visual>
                                <Grid>
                                    <Rectangle Width="40" Height="40" Fill="White" />
                                    <Path Data="M 40,0 L 0,0 0,40" Stroke="#F0F0F0" StrokeThickness="1" />
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Canvas.Background>

                    <i:Interaction.Behaviors>
                        <behaviors:CanvasInteractionBehavior/>
                    </i:Interaction.Behaviors>

                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="{Binding CanvasScale}"
                                            ScaleY="{Binding CanvasScale}"/>

                            <TranslateTransform X="{Binding CanvasOffset.X}" Y="{Binding CanvasOffset.Y}"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>

                    <!--Устройства-->
                    <ItemsControl x:Name="DevicesList" ItemsSource="{Binding Devices}" Panel.ZIndex="3" >
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="64">
                                    <Grid.Resources>
                                        <helpers:BindingProxy x:Key="DeviceProxy" Data="{Binding}" />
                                    </Grid.Resources>
                                    <Border  x:Name="SelectionBorder" Background="#4087CEFA" CornerRadius="4"
                                             Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                                             IsHitTestVisible="False"/>

                                    <StackPanel x:Name="DevicePanel"  Background="Transparent" ToolTipService.InitialShowDelay="2000">

                                        <StackPanel.ToolTip>
                                            <ToolTip Style="{StaticResource DeviceToolTipStyle}" Content="{Binding}" ContentTemplate="{StaticResource DeviceTooltipTemplate}" />
                                        </StackPanel.ToolTip>
                                        <StackPanel.ContextMenu >
                                            <ContextMenu>
                                                <MenuItem Header="Подключить"
                                                          ItemsSource="{Binding Data.LogicDevice.Ports, Source={StaticResource DeviceProxy}}">
                                                    <MenuItem.Icon>
                                                        <Image Source="/Assets/Images/connect.png" Width="20" Height="20"/>
                                                    </MenuItem.Icon>

                                                    <MenuItem.ItemContainerStyle>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Header">
                                                                <Setter.Value>
                                                                    <MultiBinding Converter="{StaticResource PortHeaderConverter}">
                                                                        <Binding Path="IsLinked"/>
                                                                        <Binding />
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Foreground" Value="{Binding IsLinked, Converter={StaticResource PortColorConverter}}" />

                                                            <Setter Property="Command" Value="{Binding DataContext.SelectDevicePortCommand, Source={x:Reference DevicesList}}" />
                                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                                        </Style>
                                                    </MenuItem.ItemContainerStyle>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem  Header="Отправить пакет" Command="{Binding DataContext.StartTryToSendPacketCommand, Source={x:Reference DevicesList}}"
                                                           CommandParameter="{Binding Data, Source={StaticResource DeviceProxy}}">
                                                    <MenuItem.Icon>
                                                        <Image Source="/Assets/Images/envelope.png" Width="20" Height="20"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Удалить" Command="{Binding DataContext.DeleteDeviceCommand, Source={x:Reference DevicesList}}"
                                                          CommandParameter="{Binding Data, Source={StaticResource DeviceProxy}}" >
                                                    <MenuItem.Icon>
                                                        <Image Source="/Assets/Images/delete.png" Width="20" Height="20"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </StackPanel.ContextMenu>
                                        <i:Interaction.Behaviors>
                                            <behaviors:DeviceDragBehavior DeviceMouseOverCommand="{Binding DataContext.DeviceMouseOverCommand, ElementName=MainCanvas}"
                                                                          DeviceMouseDownCommand="{Binding DataContext.DeviceMouseDownCommand, ElementName=MainCanvas}"
                                                                          MoveDeviceCommand="{Binding DataContext.MoveDeviceCommand, ElementName=MainCanvas}"
                                                                          CanvasScale="{Binding DataContext.CanvasScale, ElementName=MainCanvas}"/>
                                        </i:Interaction.Behaviors>
                                        <Image Width="48" Height="48" Source="{Binding ImageSource}" />
                                        <TextBlock Text="{Binding DeviceName}" HorizontalAlignment="Center" FontSize="10"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
 
                    <!--Линии подключения-->
                    <ItemsControl ItemsSource="{Binding Connections}" Panel.ZIndex="2">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Canvas>
                                    <!-- Линия -->
                                    <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                          X2="{Binding X2}" Y2="{Binding Y2}"
                                          Stroke="Gray" StrokeDashArray="4 2"
                                          StrokeThickness="2"/>

                                    <Polygon Points="0,4 4,-5 8,4"
                                             Fill="{Binding StartPoint.State, Converter={StaticResource ConnectionStateToBrushConverter}}"
                                             Canvas.Left="{Binding StartPoint.Position.X}" Canvas.Top="{Binding StartPoint.Position.Y}">
                                        <Polygon.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleX="1.5" ScaleY="1.2"/>
                                                <RotateTransform Angle="{Binding ArrowAngle}"/>
                                            </TransformGroup>
                                        </Polygon.RenderTransform>
                                    </Polygon>

                                    <Polygon Points="0,4 4,-5 8,4"
                                             Fill="{Binding EndPoint.State, Converter={StaticResource ConnectionStateToBrushConverter}}"
                                             Canvas.Left="{Binding EndPoint.Position.X}" Canvas.Top="{Binding EndPoint.Position.Y}">
                                        <Polygon.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleX="1.5" ScaleY="1.2"/>
                                                <RotateTransform Angle="{Binding ArrowAngle}"/>
                                            </TransformGroup>
                                        </Polygon.RenderTransform>
                                    </Polygon>
                                </Canvas>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!--UI Элементы пользователя-->
                    <ItemsControl ItemsSource="{Binding UIObjects}" Panel.ZIndex="1">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplateSelector>
                            <StaticResource ResourceKey="UISelector"/>
                        </ItemsControl.ItemTemplateSelector>
                    </ItemsControl>
                    <!-- ПАКЕТЫ -->
                    <ItemsControl ItemsSource="{Binding UIPackets}" Panel.ZIndex="5">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Path Data="M 0 0 L 6 0 L 6 4 L 0 4 L 0 0 L 3 2 M 6 0 L 3 2"
                                      Fill="Blue"
                                      Stroke="Black"
                                      StrokeThickness="1.5"
                                      Stretch="Uniform"
                                      Width="30" Height="30"
                                      RenderTransformOrigin="0.5,0.5">      
                                    <Path.RenderTransform>
                                        <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                    </Path.RenderTransform>
                                </Path>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!--Точки позади пакета-->
                    <ItemsControl ItemsSource="{Binding UIPacketTrails}" Panel.ZIndex="4">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Ellipse Width="4"
                                         Height="4"
                                         Fill="DodgerBlue"
                                         Opacity="{Binding Opacity}">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform ScaleX="1.5" ScaleY="1.5"></ScaleTransform>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!--Рамка выделения-->
                    <Rectangle Stroke="DodgerBlue"
                               StrokeThickness="1"
                               Fill="#331E90FF"    
                               Width="{Binding SelectionRect.Width}"
                               Height="{Binding SelectionRect.Height}"
                               Canvas.Left="{Binding SelectionRect.X}"
                               Canvas.Top="{Binding SelectionRect.Y}"
                               IsHitTestVisible="False"/>

                    <Line X1="{Binding TempConnectionLine.Start.X}" 
                          Y1="{Binding TempConnectionLine.Start.Y}"
                          X2="{Binding TempConnectionLine.End.X}" 
                          Y2="{Binding TempConnectionLine.End.Y}"
                          Stroke="#54CFFF" StrokeThickness="2" StrokeDashArray="4 2"
                          Panel.ZIndex="10"
                          IsHitTestVisible="False" 
                          Visibility="{Binding TempConnectionLine, Converter={StaticResource NullToVisibilityConverter}}" />
                </Canvas>


                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,10,10" IsHitTestVisible="False" Grid.Row="1">
                    <TextBlock Text="Движение: Средняя кнопка мыши" Foreground="#99000000" FontSize="10"/>
                    <TextBlock Text="Зум: Колесо мыши" Foreground="#99000000" FontSize="10"/>
                    <TextBlock Text="Выделение: Левая кнопка мыши" Foreground="#99000000" FontSize="10"/>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" 
                          Background="#F0F0F0" ShowsPreview="True" Cursor="SizeWE"/>

            <Grid Grid.Column="4" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock HorizontalAlignment="Center" Text="YAML CONFIGURATION" Margin="15,10" FontWeight="Bold" Foreground="#888" FontSize="10"/>
                <avalonEdit:TextEditor x:Name="YamlEditor" Grid.Row="1" Margin="10" Background="#2e2e2e" Foreground="#DCDCDC" FontFamily="Consolas" FontSize="12" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden"  Padding="10"/>

                <Grid Grid.Row="2" Margin="10,0,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="PathDisplay" Text="{Binding CurrentFilePath, Mode=OneWay}"  IsReadOnly="True" FontSize="11" Padding="5" VerticalContentAlignment="Center" Background="#F9F9F9" BorderBrush="#DDD"/>

                    <Button Command="{Binding OpenFinderFileDialogCommand}" Grid.Column="1" Content="📁" Width="35" Margin="5,0,0,0" Style="{StaticResource ActionBtn}" Cursor="Hand"/>
                </Grid>

                <StackPanel Grid.Row="3"  Margin="10,0,10,10">
                    <Button Content="Подтвердить &amp; Сбилдить" Command="{Binding ApplyAndBuildYamlFileCommand}" Style="{StaticResource ActionBtn}" Background="#007ACC" Foreground="White" FontWeight="Bold" Height="35" Margin="0,0,5,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>