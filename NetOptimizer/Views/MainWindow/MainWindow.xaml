<Window x:Class="NetOptimizer.Views.MainWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:conv="clr-namespace:NetOptimizer.Convertors"
        xmlns:local="clr-namespace:NetOptimizer"
        xmlns:behaviors="clr-namespace:NetOptimizer.Behaviors"
        mc:Ignorable="d"
        Icon="/Assets/Icons/gnologo.ico"
        Title="{Binding ProjectName}" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <conv:DeviceTypeToIconConverter x:Key="DeviceTypeToIconConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/ResourcesDictionary/MainWindowResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
        
    </Window.Resources>

    <DockPanel Background="#F8F8F8">
        <Menu DockPanel.Dock="Top" Background="White" BorderThickness="0,0,0,1" BorderBrush="#F0F0F0" Foreground="Black" Padding="5" Cursor="Hand">
            <MenuItem  Header="File">
                <MenuItem.Icon>
                    <Image Source="/Assets/Images/file.png" />
                </MenuItem.Icon>
                <MenuItem Header="Новый проект" />
                <MenuItem Header="Открыть проект" />
                <Separator />
                <MenuItem Header="Сохранить и выйти" />
            </MenuItem>
            <MenuItem Header="Edit" >
                <MenuItem.Icon>
                    <Image Source="/Assets/Images/edit.png" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem.Icon>
                    <Image Source="/Assets/Images/help.png" />
                </MenuItem.Icon>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="220" MaxWidth="450"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="500"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TabControl Grid.Row="3"
                            Background="Transparent"
                            BorderThickness="0"
                            TabStripPlacement="Bottom"
                            HorizontalAlignment="Stretch">
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                  Margin="0"
                                  ContentSource="SelectedContent"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                                <UniformGrid Rows="1" Columns="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Items.Count}" IsItemsHost="True" VerticalAlignment="Bottom"/>
                            </Grid>
                        </ControlTemplate>
                    </TabControl.Template>

                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,8"/>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Style="{StaticResource ModernTabItemStyle}">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Source="/Assets/Images/redact.png" Width="18" Height="18" Margin="0,0,8,0"/>
                                <TextBlock Text="Редактор" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,40">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="КОНФИГУРАЦИЯ СЕТИ" Grid.Row="0" 
                                           HorizontalAlignment="Center" FontWeight="Bold" 
                                           Foreground="#555" Margin="0,10,0,20"/>

                                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                                    <TextBlock Text="Тип объекта:" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#333"/>

                                    <ItemsControl ItemsSource="{Binding editorViewModel.AvailableTypes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding TypeOfObject}" 
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Separator Margin="10,15,10,0" Background="#EEE"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Margin="0,0,0,15">
                                    <TextBlock Text="Устройства:" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#333"/>

                                    <ItemsControl ItemsSource="{Binding editorViewModel.AvailableDevices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="25"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="25"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Image Source="{Binding Type, Converter={StaticResource DeviceTypeToIconConverter}}" 
                                                           Width="18" Height="18" HorizontalAlignment="Left"/>

                                                    <TextBlock Foreground="Black" Grid.Column="1" 
                                                               Text="{Binding DeviceName}" VerticalAlignment="Center"/>

                                                    <Slider Grid.Column="2" 
                                                            Minimum="0" 
                                                            Maximum="{Binding MaxCount}" 
                                                            Value="{Binding Count, Mode=TwoWay}"
                                                            TickFrequency="1" 
                                                            IsSnapToTickEnabled="True"
                                                            VerticalAlignment="Center"/>
                                                    
                                                    <TextBlock Grid.Column="3" 
                                                               Text="{Binding Count}" 
                                                               VerticalAlignment="Center" 
                                                               HorizontalAlignment="Right" 
                                                               FontWeight="Bold" 
                                                               Foreground="#4A89F3"/>       
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Separator Margin="10,15,10,0" Background="#EEE"/>
                                </StackPanel>

                                <StackPanel Grid.Row="3">
                                    <TextBlock Text="Бюджет:" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#333"/>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="25"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="25"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Source="/Assets/Images/rubl.png" Width="18" Height="18" HorizontalAlignment="Left"/>
                                        <TextBlock Foreground="Black" Grid.Column="1" Text="Лимит (тыс.)" VerticalAlignment="Center"/>
                                        <Slider x:Name="SliderBudget" Grid.Column="2" Minimum="10" Maximum="500" TickFrequency="10" IsSnapToTickEnabled="True"/>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding ElementName=SliderBudget, Path=Value}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#4A89F3"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="4" VerticalAlignment="Bottom" >
                                    <Button Content="Создать" Height="30" Width="150" Foreground="White" FontWeight="SemiBold" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="#4A89F3" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#5B9AFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#3A79E3"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                </StackPanel>

                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Style="{StaticResource ModernTabItemStyle}">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Source="/Assets/Images/topology.png" Width="20" Height="20" Margin="0,0,5,0"/>
                                <TextBlock Text="Песочница" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="DEVICES"
                                       HorizontalAlignment="Center"
                                       Margin="10,10,0,0"
                                       FontWeight="Bold"
                                       Foreground="#888"
                                       FontSize="10"/>
                            <ScrollViewer behaviors:ScrollBarWheelDirectionBehavior.OrientationScroll="Horizontal" Grid.Row="1"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Margin="10,5">
                                <ItemsControl ItemsSource="{Binding sandboxViewModel.AvailableDevices}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="5"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Vertical" Margin="0,0,12,0" Cursor="Hand">
                                                <Border x:Name="iconBorder" Background="White" BorderThickness="1" BorderBrush="#EDEDED" Width="45" Height="45" CornerRadius="10">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                       Command="{Binding DataContext.sandboxViewModel.OpenCreateDeviceWindowCommand, 
                                                                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                       CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <Image UseLayoutRounding="True" Source="{Binding Type, Converter={StaticResource DeviceTypeToIconConverter}}"  Margin="5"/>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#DEDEDE"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                                <TextBlock Text="{Binding DeviceName}"
                                                           HorizontalAlignment="Center"
                                                           FontSize="10"
                                                           Foreground="#555"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <ScrollViewer behaviors:ScrollBarWheelDirectionBehavior.OrientationScroll="Vertical"
                                          Grid.Row="2" Margin="0,0,0,35"
                                          HorizontalScrollBarVisibility="Disabled"  
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Created Devices"
                                               HorizontalAlignment="Center"
                                               Margin="10,10,0,0"
                                               FontWeight="Bold"
                                               Foreground="#888"
                                               FontSize="10"/>
                                    
                                    <ListBox ItemsSource="{Binding DevicesOnCanvas}"
                                             SelectedItem="{Binding SelectedDevice}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             HorizontalContentAlignment="Stretch">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemBorder" Background="Transparent" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#F5F5F5"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#E3F2FD"/>
                                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2196F3"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Height="50" Background="Transparent" Padding="5,0">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Подключиться"
                                                  Command="{Binding PlacementTarget.Tag.ConnectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <Image Source="/Assets/Images/connect.png"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>

                                                            <MenuItem Header="Изменить"
                                                  Command="{Binding PlacementTarget.Tag.OpenUpdateDeviceWindowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <Image Source="/Assets/Images/reconnect.png"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>

                                                            <Separator />

                                                            <MenuItem Header="Удалить" Foreground="Red"
                                                  Command="{Binding PlacementTarget.Tag.RemoveDeviceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <Image Source="/Assets/Images/delete.png"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>

                                                    <Border.Tag>
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ListBox}" />
                                                    </Border.Tag>

                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Width="30" Height="30" Margin="10"
                                           Source="{Binding LogicDevice.Type, Converter={StaticResource DeviceTypeToIconConverter}}" />
                                                        <StackPanel VerticalAlignment="Center">
                                                            <Label Content="{Binding DeviceName}" Foreground="Black" FontSize="14" Padding="0"/>
                                                            <TextBlock Text="{Binding DeviceModel}" Foreground="Gray" FontSize="10" Margin="5,0,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" 
                          Background="#F0F0F0" ShowsPreview="True" Cursor="SizeWE"/>

            <Grid Grid.Column="2" Background="#DFE3E6" ClipToBounds="True">
                <Canvas x:Name="MainCanvas" Width="3000" Height="3000" 
                        MouseWheel="MainCanvas_MouseWheel" MouseDown="MainCanvas_MouseDown" 
                        MouseUp="MainCanvas_MouseUp" MouseMove="MainCanvas_MouseMove" 
                        Margin="-288,-247,-36,-247">

                    <Rectangle x:Name="SelectionBox" Stroke="DodgerBlue" StrokeThickness="1" 
                               Fill="#331E90FF" Visibility="Collapsed" IsHitTestVisible="False"/>

                    <Canvas.Background>
                        <VisualBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                            <VisualBrush.Visual>
                                <Grid>
                                    <Rectangle Width="40" Height="40" Fill="White" />
                                    <Path Data="M 40,0 L 0,0 0,40" Stroke="#F0F0F0" StrokeThickness="1" />
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Canvas.Background>

                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1" />
                            <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0" />
                        </TransformGroup>
                    </Canvas.RenderTransform>
                </Canvas>

                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10" IsHitTestVisible="False">
                    <TextBlock Text="Движение: Средняя кнопка мыши" Foreground="#99000000" FontSize="10"/>
                    <TextBlock Text="Зум: Колесо мыши" Foreground="#99000000" FontSize="10"/>
                    <TextBlock Text="Выделение: Левая кнопка мыши" Foreground="#99000000" FontSize="10"/>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" 
                          Background="#F0F0F0" ShowsPreview="True" Cursor="SizeWE"/>

            <Grid Grid.Column="4" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock HorizontalAlignment="Center" Text="YAML CONFIGURATION" Margin="15,10" FontWeight="Bold" Foreground="#888" FontSize="10"/>
                <avalonEdit:TextEditor x:Name="YamlEditor" Grid.Row="1" Margin="10" Background="#2e2e2e" Foreground="#DCDCDC" FontFamily="Consolas" FontSize="12" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden"  Padding="10"/>

                <Grid Grid.Row="2" Margin="10,0,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="PathDisplay" Text="{Binding CurrentFilePath, Mode=OneWay}"  IsReadOnly="True" FontSize="11" Padding="5" VerticalContentAlignment="Center" Background="#F9F9F9" BorderBrush="#DDD"/>

                    <Button Command="{Binding OpenFinderFileDialogCommand}" Grid.Column="1" Content="📁" Width="35" Margin="5,0,0,0" Style="{StaticResource ActionBtn}" Cursor="Hand"/>
                </Grid>

                <StackPanel Grid.Row="3"  Margin="10,0,10,10">
                    <Button Content="Подтвердить &amp; Сбилдить" Command="{Binding ApplyAndBuildYamlFileCommand}" Style="{StaticResource ActionBtn}" Background="#007ACC" Foreground="White" FontWeight="Bold" Height="35" Margin="0,0,5,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>