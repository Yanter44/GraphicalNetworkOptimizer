<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:NetOptimizer.Convertors"
                    xmlns:selectors="clr-namespace:NetOptimizer.Views.Selectors"
                    xmlns:behaviors="clr-namespace:NetOptimizer.Behaviors"
                    xmlns:i="http://schemas.microsoft.com/xaml/behaviors">

    <!-- =====================Конверторы==================== -->
    <conv:PortsToStringConverter x:Key="PortsToStringConverter"/>

    <!-- =====================Стили==================== -->
 

    <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="BorderBrush" Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="1"/>
        
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="SelectionBrush" Value="#B3E5FC"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" 
                                  Focusable="false" 
                                  HorizontalScrollBarVisibility="Hidden" 
                                  VerticalScrollBarVisibility="Hidden"
                                  Margin="{TemplateBinding Padding}"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#BDBDBD"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#A0E0F0"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- ===================== Дата Темплейты ==================== -->
    
    
    <!--Дата темплейты физических свойств-->
    <DataTemplate x:Key="PcSpecsTemplate">
        <Grid Margin="20,10,20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="{Binding ImagePath}" 
                  Width="60" Height="60"
                  VerticalAlignment="Top" Margin="0,0,15,0">
                    <Image.Effect>
                        <DropShadowEffect ShadowDepth="5" Opacity="0.2" BlurRadius="5"/>
                    </Image.Effect>
                </Image>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <TextBlock Text="{Binding DeviceName}" 
                          FontSize="20" FontWeight="DemiBold" Foreground="Black"/>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/zavod.png" Width="18" Height="18" Margin="0,0,8,0" />
                        <TextBlock Text="Производитель: " Foreground="Gray" FontSize="14"/>
                        <TextBlock Text="{Binding LogicDevice.Vendor}" Foreground="Black" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Image Source="/Assets/Images/model.png" Width="18" Height="18" Margin="0,0,8,0" />
                        <TextBlock Text="Модель: " Foreground="Gray" FontSize="14"/>
                        <TextBlock Text="{Binding DeviceModel}" Foreground="Black" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Image Source="/Assets/Images/settings.png" Width="20" Height="20" Margin="0,0,8,0"/>
                    <TextBlock Text="Технические характеристики:" FontWeight="Medium" Foreground="Gray" FontSize="15"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Image Source="/Assets/Images/processor.png" Width="18" Height="18"></Image>
                        <TextBlock Text="{Binding LogicDevice.HardwareSpecs.CpuModel, StringFormat='Процессор: {0}'}" Foreground="Black"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"  Margin="0,5,0,0">
                        <Image Source="/Assets/Images/ram.png" Width="18" Height="18"></Image>
                        <TextBlock  Foreground="Black">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Оперативная память: {0}Gb {1}">
                                    <Binding Path="LogicDevice.HardwareSpecs.RamAmountGb" />
                                    <Binding Path="LogicDevice.HardwareSpecs.RamType" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Image Source="/Assets/Images/ssd.png" Width="18" Height="18"></Image>
                        <TextBlock Foreground="Black">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Накопитель: {0}Gb {1}">
                                    <Binding Path="LogicDevice.HardwareSpecs.StorageAmountGb" />
                                    <Binding Path="LogicDevice.HardwareSpecs.StorageType" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Image Source="/Assets/Images/wifi.png" Width="18" Height="18"></Image>
                        <TextBlock Foreground="Black" Text="{Binding LogicDevice.WifiOptions.HasWiFi, StringFormat='Wifi: {0}'}"></TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Image Source="/Assets/Images/port.png" Width="18" Height="18"></Image>
                        <TextBlock Text="Порты:" Foreground="Black"/>
                    </StackPanel>
                    <TextBlock Margin="20,0,0,0" Text="{Binding LogicDevice.Ports, Converter={StaticResource PortsToStringConverter}}" Foreground="Black"></TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="Средняя цена на рынке: " Foreground="Black"></TextBlock>
                    <TextBlock Text="{Binding LogicDevice.AveragePrice, StringFormat='{}{0:N0}'}" 
                               Foreground="#228E3F" FontWeight="Bold"/>
                    <TextBlock Text=" ₽" Foreground="Black"></TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>
    </DataTemplate>
    <DataTemplate x:Key="SwitchSpecsTemplate">
        
    </DataTemplate>
    <selectors:DeviceSpecsSelector x:Key="DeviceSpecsSelector"
        PcTemplate="{StaticResource PcSpecsTemplate}"/>
    <!--Дата темплейты сетевых свойств-->
    <DataTemplate x:Key="PcNetSpecsTemplate">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="/Assets/Images/internet3.png"
                       Width="100" Height="100"
                       VerticalAlignment="Top" Margin="20,25,15,0" 
                       SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="Fant">
                </Image>

                <Grid Grid.Column="1" VerticalAlignment="Top" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
                        <RadioButton x:Name="DhcpRadio" 
                     Content="DHCP" 
                     GroupName="IPMode" 
                     IsChecked="{Binding LogicDevice.NetworkSettings.IsDhcp}"
                     FontSize="14" Margin="0,0,0,5"/>
                        <RadioButton x:Name="StaticRadio" 
                     Content="Статически" 
                     GroupName="IPMode" 
                     IsChecked="{Binding LogicDevice.NetworkSettings.IsStatic}"
                     FontSize="14"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="IP-Адрес:" Foreground="#3A3A3A" FontSize="14" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="1" Grid.Column="1"
                               Style="{StaticResource ModernTextBoxStyle}"  Text="{Binding LogicDevice.NetworkSettings.IpAddress}"
                               IsEnabled="{Binding IsChecked, ElementName=StaticRadio}"  TextAlignment="Center" Margin="10,5">
                        <i:Interaction.Behaviors>
                            <behaviors:TextBoxBehaviors Mode="NumbersAndDots"/>
                        </i:Interaction.Behaviors>
                    </TextBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Маска подсети:" Foreground="#3A3A3A" FontSize="14" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="2" Grid.Column="1" 
                               Style="{StaticResource ModernTextBoxStyle}"  Text="{Binding LogicDevice.NetworkSettings.SubnetMask}"
                               IsEnabled="{Binding IsChecked, ElementName=StaticRadio}"
                               TextAlignment="Center" Margin="10,5">
                        <i:Interaction.Behaviors>
                            <behaviors:TextBoxBehaviors Mode="NumbersAndDots"/>
                        </i:Interaction.Behaviors>
                    </TextBox>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Шлюз по умолчанию:" Foreground="#3A3A3A" FontSize="14" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="3" Grid.Column="1"
                               Style="{StaticResource ModernTextBoxStyle}"  Text="{Binding LogicDevice.NetworkSettings.Gateway}"
                               IsEnabled="{Binding IsChecked, ElementName=StaticRadio}"
                               TextAlignment="Center" Margin="10,5">
                        <i:Interaction.Behaviors>
                            <behaviors:TextBoxBehaviors Mode="NumbersAndDots"/>
                        </i:Interaction.Behaviors>
                    </TextBox>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Dns-Сервер:" Foreground="#3A3A3A" FontSize="14" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="4"  Grid.Column="1" 
                               Style="{StaticResource ModernTextBoxStyle}" Text="{Binding LogicDevice.NetworkSettings.DNS}"
                               IsEnabled="{Binding IsChecked, ElementName=StaticRadio}"
                               TextAlignment="Center" Margin="10,5">
                        <i:Interaction.Behaviors>
                            <behaviors:TextBoxBehaviors Mode="NumbersAndDots"/>
                        </i:Interaction.Behaviors>
                    </TextBox>
                </Grid>
            </Grid>
        </Grid>
    </DataTemplate>
    <selectors:DeviceNetSpecsSelector x:Key="DeviceNetSpecsSelector"
                                      PcTemplate="{StaticResource PcNetSpecsTemplate}"/>
</ResourceDictionary>